{
  "name": "md2docx",
  "version": "2.0.0",
  "description": "Convert Markdown to structured DOCX with native Word equations and embedded images.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "md2docx": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "public",
    "scripts",
    "README.md"
  ],
  "engines": {
    "node": "\u003e=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server/index.ts",
    "start": "tsx src/server/index.ts",
    "convert": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check \u0026\u0026 npm run lint \u0026\u0026 npm run typecheck \u0026\u0026 npm test \u0026\u0026 npm run build",
    "prepack": "npm run build"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "docx": "^9.0.0",
    "express": "^4.21.2",
    "image-size": "^2.0.2",
    "marked": "^14.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.30.0",
    "jszip": "^3.10.1",
    "prettier": "^3.6.2",
    "supertest": "^7.1.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
